# Shared
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_erp?schema=public"

# Auth
JWT_SECRET="change-me-very-strong"
JWT_EXPIRES_IN="1d"

# Comma-separated allowed frontend origins for API CORS
# Example: "http://localhost:5173,https://erp.yourschool.com"
CORS_ORIGIN="http://localhost:5173"

# Frontend
VITE_API_BASE_URL="http://localhost:4000/api"
